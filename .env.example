# ============================================
# MoneyBot v2 — Переменные окружения
# ============================================
# Скопировать в .env и заполнить реальными значениями:
#   cp .env.example .env

# Окружение: development | production
ENVIRONMENT=production

# ---- PostgreSQL ----
POSTGRES_USER=moneybot
POSTGRES_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
POSTGRES_DB=moneybot
POSTGRES_PORT=5432

# ---- Redis ----
REDIS_PORT=6379

# ---- Порты приложения ----
BACKEND_PORT=8001
FRONTEND_PORT=5173

# ---- JWT ----
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# ---- Шифрование API-ключей бирж (Fernet) ----
# Сгенерировать: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_COMMAND_ABOVE

# ---- CORS ----
# Через запятую, без пробелов. Для production — ваш домен.
CORS_ORIGINS=https://your-domain.com

# ---- Frontend API URL ----
# URL, по которому фронтенд обращается к бэкенду (через nginx).
VITE_API_URL=https://your-domain.com
